-- 精简版坐标传送系统（可开关/隐藏/拖拽）
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")
local UserInputService = game:GetService("UserInputService")

local waypoints = {
    {name = "坐标点1", position = Vector3.new(-49.5, 3.6, -82.7)},
    {name = "坐标点2", position = Vector3.new(0, 0, 0)},
    {name = "坐标点3", position = Vector3.new(0, 0, 0)},
}

-- 传送函数
local function teleportToWaypoint(waypoint)
    if character and rootPart then
        rootPart.CFrame = CFrame.new(waypoint.position)
        print("已传送到: " .. waypoint.name)
    end
end

-- 保存当前坐标
local function saveCurrentPosition(waypointIndex)
    if character and rootPart then
        local currentPos = rootPart.Position
        waypoints[waypointIndex].position = currentPos
        print(waypoints[waypointIndex].name .. " 已更新坐标: " .. tostring(currentPos))
        updateGUI()
    end
end

