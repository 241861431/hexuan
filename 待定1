-- 按钮容器
local buttonContainer = Instance.new("Frame")
buttonContainer.Size = UDim2.new(1, -20, 0, #waypoints * 45)
buttonContainer.Position = UDim2.new(0, 10, 0, 35)
buttonContainer.BackgroundTransparency = 1
buttonContainer.Parent = mainFrame

-- 更新GUI
function updateGUI()
    for _, child in ipairs(buttonContainer:GetChildren()) do
        child:Destroy()
    end
    
    mainFrame.Size = UDim2.new(0, 300, 0, 40 + (#waypoints * 45))
    buttonContainer.Size = UDim2.new(1, -20, 0, #waypoints * 45)
    
    for i, waypoint in ipairs(waypoints) do
        local yPos = (i-1) * 45
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0, 180, 0, 35)
        label.Position = UDim2.new(0, 0, 0, yPos)
        label.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        label.BackgroundTransparency = 0.5
        label.Text = waypoint.name .. "\n" .. string.format("%.1f, %.1f, %.1f", waypoint.position.X, waypoint.position.Y, waypoint.position.Z)
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 11
        label.Parent = buttonContainer
        
        local saveButton = Instance.new("TextButton")
        saveButton.Size = UDim2.new(0, 30, 0, 35)
        saveButton.Position = UDim2.new(0, 185, 0, yPos)
        saveButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        saveButton.Text = "💾"
        saveButton.TextSize = 14
        saveButton.Parent = buttonContainer
        saveButton.MouseButton1Click:Connect(function()
            saveCurrentPosition(i)
        end)
        
        local teleportButton = Instance.new("TextButton")
        teleportButton.Size = UDim2.new(0, 50, 0, 35)
        teleportButton.Position = UDim2.new(0, 220, 0, yPos)
        teleportButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
        teleportButton.Text = "传送"
        teleportButton.TextSize = 12
        teleportButton.Parent = buttonContainer
        teleportButton.MouseButton1Click:Connect(function()
            teleportToWaypoint(waypoint)
        end)
    end
end

